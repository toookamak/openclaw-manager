# Required (choose one)
# Option A: Single admin (legacy, still supported)
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Option B: Multiple admins (comma-separated, recommended)
# ADMIN_TELEGRAM_IDS=123456789,987654321

BOT_TOKEN=your_telegram_bot_token_here

# Optional
# TZ=Asia/Shanghai
# DATA_DIR=/app/data
# STATE_EMOJI_ENABLED=true
# ALERT_CHECK_INTERVAL_SEC=60 (can be changed at runtime via Settings)
# OPENCLAW_BINARY=openclaw
